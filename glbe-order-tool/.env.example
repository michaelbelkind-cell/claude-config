# Copy to .env and fill in real values. NEVER commit .env.

# Target environment: qa (default). staging/prod are gated (see GLBE_ALLOW_NON_QA).
GLBE_ENV=qa

# Secrets (rotate the QA keys that were shared in chat).
# AuthToken for connect-* return-configuration endpoint:
GLBE_AUTH_TOKEN=
# X-API-KEY for the order-creation service (/Template, /Orders):
GLBE_API_KEY=

# Safety gate: must be "true" to run against any non-QA environment.
GLBE_ALLOW_NON_QA=false
